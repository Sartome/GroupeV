<Window x:Class="GroupeV.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GroupeV — Démarrage"
        MinHeight="380" MinWidth="480"
        Height="440" Width="560"
        Background="{StaticResource NeuBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <!-- Carte centrale sur fond gris — WindowStyle=None conservé pour l'effet splash sans chrome -->
    <Border Background="{StaticResource NeuSurfaceBrush}"
            BorderThickness="1"
            BorderBrush="{StaticResource NeuDividerBrush}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ CONTENU PRINCIPAL ═══ -->
            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="48,40,48,32">

                <!-- Logo -->
                <Border Width="64" Height="64" CornerRadius="14"
                        Background="{StaticResource NeuAccentBgBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock Text="€" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource NeuAccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Titre -->
                <TextBlock Text="GROUPE V"
                           FontFamily="{StaticResource NeuFontFamily}"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Text="Système de vente intelligent"
                           FontFamily="{StaticResource NeuFontFamily}"
                           FontSize="14"
                           Foreground="{StaticResource NeuTextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Barre de progression flat -->
                <Border Background="{StaticResource NeuInputBgBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource NeuDividerBrush}"
                        CornerRadius="4" Height="6" Width="320"
                        HorizontalAlignment="Center" Margin="0,0,0,14"
                        ClipToBounds="True">
                    <Rectangle x:Name="LoadingBar"
                               HorizontalAlignment="Left" Width="0"
                               RadiusX="4" RadiusY="4">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="{StaticResource NeuAccent}"/>
                        </Rectangle.Fill>
                    </Rectangle>
                </Border>

                <!-- Texte de statut -->
                <TextBlock x:Name="LoadingText" Text="Initialisation..."
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                           Foreground="{StaticResource NeuTextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <TextBlock x:Name="StatusText" Text="Chargement des modules..."
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                           Foreground="{StaticResource NeuTextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Messages de progression -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="Msg1"
                               Text="✓  Connexion à la base de données"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                               Foreground="{StaticResource NeuSuccessBrush}"
                               HorizontalAlignment="Center" Opacity="0"/>
                    <TextBlock x:Name="Msg2"
                               Text="✓  Chargement des produits"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                               Foreground="{StaticResource NeuSuccessBrush}"
                               HorizontalAlignment="Center" Opacity="0" Margin="0,4,0,0"/>
                    <TextBlock x:Name="Msg3"
                               Text="✓  Initialisation de l'interface"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                               Foreground="{StaticResource NeuSuccessBrush}"
                               HorizontalAlignment="Center" Opacity="0" Margin="0,4,0,0"/>
                    <TextBlock x:Name="Msg4"
                               Text="✓  Configuration du système"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                               Foreground="{StaticResource NeuSuccessBrush}"
                               HorizontalAlignment="Center" Opacity="0" Margin="0,4,0,0"/>
                </StackPanel>

            </StackPanel>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="1"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource NeuDividerBrush}"
                    Padding="24,10">
                <TextBlock
                           FontFamily="{StaticResource NeuMonoFont}" FontSize="10"
                           Foreground="{StaticResource NeuTextTertiaryBrush}"
                           HorizontalAlignment="Center"><Run Text="v"/><Run Language="fr-fr" Text="1"/><Run Text=".0.0 | © 202"/><Run Language="fr-fr" Text="6"/><Run Text=" GroupeV"/></TextBlock>
            </Border>

        </Grid>
    </Border>
</Window>
