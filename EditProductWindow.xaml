<Window x:Class="GroupeV.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Éditeur de Produit"
        MinHeight="580" MinWidth="480"
        Height="760" Width="560"
        Background="{StaticResource NeuBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Contenu scrollable -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource NeuSurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource NeuDividerBrush}"
                Padding="28,18">
            <StackPanel>
                <TextBlock x:Name="HeaderTextBlock" Text="Modifier le Produit"
                           FontFamily="{StaticResource NeuFontFamily}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}"/>
                <TextBlock Text="Gestion des produits"
                           FontFamily="{StaticResource NeuFontFamily}"
                           FontSize="12"
                           Foreground="{StaticResource NeuTextSecondaryBrush}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ CONTENU SCROLLABLE ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,20,28,20">

                <!-- Message de statut -->
                <Border x:Name="StatusBorder"
                        Background="{StaticResource NeuInfoBadgeBgBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource NeuInfoBadgeBgBrush}"
                        CornerRadius="6" Padding="14,10"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock" Text=""
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                               Foreground="{StaticResource NeuInfoBadgeFgBrush}"
                               TextWrapping="Wrap" FontWeight="Medium"/>
                </Border>

                <!-- ID Produit (mode édition) -->
                <Border x:Name="ProductIdBorder"
                        Style="{StaticResource NeuCardInset}"
                        Padding="12,8" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ID Produit : "
                                   FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                   Foreground="{StaticResource NeuTextSecondaryBrush}"/>
                        <TextBlock x:Name="ProductIdTextBlock" Text="0"
                                   FontFamily="{StaticResource NeuMonoFont}" FontSize="12"
                                   Foreground="{StaticResource NeuAccentBrush}" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Description -->
                <TextBlock Text="Description du produit *"
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="DescriptionTextBox"
                         Style="{StaticResource NeuTextBox}"
                         Margin="0,0,0,20"
                         Height="72" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         MaxLength="255"/>

                <!-- ══ TYPE DE VENTE — 3 cartes sélectionnables ══ -->
                <TextBlock Text="Type de vente *"
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Achat direct -->
                    <Border Grid.Column="0" x:Name="CardBuy"
                            Background="{StaticResource NeuSurfaceBrush}"
                            BorderThickness="1.5" BorderBrush="{StaticResource NeuDividerBrush}"
                            CornerRadius="8" Padding="12,14"
                            Cursor="Hand" MouseLeftButtonUp="CardBuy_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🛒" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CardBuyTitle" Text="Achat direct"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="Vente immédiate à prix fixe"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="10"
                                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Enchère -->
                    <Border Grid.Column="2" x:Name="CardAuction"
                            Background="{StaticResource NeuSurfaceBrush}"
                            BorderThickness="1.5" BorderBrush="{StaticResource NeuDividerBrush}"
                            CornerRadius="8" Padding="12,14"
                            Cursor="Hand" MouseLeftButtonUp="CardAuction_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔨" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CardAuctionTitle" Text="Enchère"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="Mise aux enchères avec temps limite"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="10"
                                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Vente groupée -->
                    <Border Grid.Column="4" x:Name="CardGroup"
                            Background="{StaticResource NeuSurfaceBrush}"
                            BorderThickness="1.5" BorderBrush="{StaticResource NeuDividerBrush}"
                            CornerRadius="8" Padding="12,14"
                            Cursor="Hand" MouseLeftButtonUp="CardGroup_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CardGroupTitle" Text="Vente groupée"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="Vente conditionnée au nombre d'acheteurs"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="10"
                                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══ SECTION : ACHAT DIRECT ══ -->
                <StackPanel x:Name="SectionBuy">
                    <TextBlock Text="Prix HT (€) *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PrixHtBuyBox" Style="{StaticResource NeuTextBox}"
                             Margin="0,0,0,8" MaxLength="15"
                             TextChanged="PrixHtBuy_TextChanged"/>

                    <Border Background="{StaticResource NeuInfoBadgeBgBrush}"
                            CornerRadius="6" Padding="10,7" Margin="0,0,0,8"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TVA "
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                            <TextBlock Text="20,00%"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       FontWeight="Bold" Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                            <TextBlock Text="  (taux défini par l'administration)"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Prix TTC (€) *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PrixTtcBuyBox" Style="{StaticResource NeuTextBox}"
                             Margin="0,0,0,16" MaxLength="15"
                             TextChanged="PrixTtcBuy_TextChanged"/>

                    <TextBlock Text="Quantité disponible"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="QuantityBuyBox" Style="{StaticResource NeuTextBox}"
                             Text="1" MaxLength="6" Margin="0,0,0,4"/>
                    <TextBlock Text="Nombre d'articles disponibles à la vente"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,20"/>
                </StackPanel>

                <!-- ══ SECTION : ENCHÈRE ══ -->
                <StackPanel x:Name="SectionAuction" Visibility="Collapsed">
                    <TextBlock Text="Prix de départ (€) *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PrixAuctionBox" Style="{StaticResource NeuTextBox}"
                             Margin="0,0,0,16" MaxLength="15"/>

                    <TextBlock Text="Fin de l'enchère *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                BorderThickness="1" BorderBrush="{StaticResource NeuDividerBrush}"
                                CornerRadius="6" Padding="0" Background="{StaticResource NeuSurfaceBrush}">
                            <DatePicker x:Name="AuctionEndDatePicker"
                                        BorderThickness="0" Background="Transparent"
                                        FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                                        VerticalContentAlignment="Center" Padding="12,0" Height="40"/>
                        </Border>
                        <TextBox Grid.Column="2" x:Name="AuctionEndTimeBox"
                                 Style="{StaticResource NeuTextBox}"
                                 Text="23:59" MaxLength="5" Height="40"/>
                    </Grid>
                    <TextBlock Text="L'enchère se terminera automatiquement à cette date"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Quantité disponible"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="QuantityAuctionBox" Style="{StaticResource NeuTextBox}"
                             Text="1" MaxLength="6" Margin="0,0,0,4"/>
                    <TextBlock Text="Nombre d'articles disponibles à la vente"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,20"/>
                </StackPanel>

                <!-- ══ SECTION : VENTE GROUPÉE ══ -->
                <StackPanel x:Name="SectionGroup" Visibility="Collapsed">
                    <TextBlock Text="Prix HT (€) *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PrixHtGroupBox" Style="{StaticResource NeuTextBox}"
                             Margin="0,0,0,8" MaxLength="15"
                             TextChanged="PrixHtGroup_TextChanged"/>

                    <Border Background="{StaticResource NeuInfoBadgeBgBrush}"
                            CornerRadius="6" Padding="10,7" Margin="0,0,0,8"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TVA "
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                            <TextBlock Text="20,00%"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       FontWeight="Bold" Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                            <TextBlock Text="  (taux défini par l'administration)"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                                       Foreground="{StaticResource NeuInfoBadgeFgBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Prix TTC (€) *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PrixTtcGroupBox" Style="{StaticResource NeuTextBox}"
                             Margin="0,0,0,16" MaxLength="15"
                             TextChanged="PrixTtcGroup_TextChanged"/>

                    <TextBlock Text="Nombre d'acheteurs requis *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="GroupBuyersBox" Style="{StaticResource NeuTextBox}"
                             Text="1" MaxLength="6" Margin="0,0,0,4"/>
                    <TextBlock Text="Le produit ne sera vendu que si ce nombre d'acheteurs est atteint."
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Date/heure limite *"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                BorderThickness="1" BorderBrush="{StaticResource NeuDividerBrush}"
                                CornerRadius="6" Padding="0" Background="{StaticResource NeuSurfaceBrush}">
                            <DatePicker x:Name="GroupDeadlineDatePicker"
                                        BorderThickness="0" Background="Transparent"
                                        FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                                        VerticalContentAlignment="Center" Padding="12,0" Height="40"/>
                        </Border>
                        <TextBox Grid.Column="2" x:Name="GroupDeadlineTimeBox"
                                 Style="{StaticResource NeuTextBox}"
                                 Text="23:59" MaxLength="5" Height="40"/>
                    </Grid>
                    <TextBlock Text="Si le nombre d'acheteurs requis n'est pas atteint à cette date, la vente échoue."
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Quantité disponible"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="QuantityGroupBox" Style="{StaticResource NeuTextBox}"
                             Text="1" MaxLength="6" Margin="0,0,0,4"/>
                    <TextBlock Text="Nombre d'articles disponibles à la vente"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                               Foreground="{StaticResource NeuTextTertiaryBrush}" Margin="0,0,0,20"/>
                </StackPanel>

                <!-- Catégorie -->
                <TextBlock Text="Catégorie"
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                <ComboBox x:Name="CategoryComboBox"
                          Style="{StaticResource NeuComboBox}"
                          DisplayMemberPath="Libelle"
                          SelectedValuePath="IdCategorie"
                          Margin="0,0,0,20"/>

                <!-- Image -->
                <TextBlock Text="Image du produit (optionnel)"
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                <Border x:Name="ImagePreviewBorder"
                        BorderThickness="1" BorderBrush="{StaticResource NeuDividerBrush}"
                        Background="{StaticResource NeuInputBgBrush}"
                        CornerRadius="8" Height="120" Margin="0,0,0,8"
                        ClipToBounds="True"
                        AllowDrop="True" Drop="ImageDrop_Drop" DragOver="ImageDrop_DragOver"
                        Cursor="Hand" MouseLeftButtonUp="ImagePreview_Click">
                    <Grid>
                        <Image x:Name="ImagePreview" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel x:Name="ImageDropPlaceholder"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📷" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Glissez-déposez ou cliquez pour choisir"
                                       FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBox x:Name="ImageUrlTextBox"
                         Style="{StaticResource NeuTextBox}"
                         Margin="0,0,0,8" IsReadOnly="True" FontSize="11" MaxLength="255"/>

                <TextBlock Text="Texte alternatif (optionnel)"
                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource NeuTextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="ImageAltTextBox"
                         Style="{StaticResource NeuTextBox}"
                         Margin="0,0,0,24" MaxLength="255"/>

                <!-- Boutons d'action -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Annuler"
                            Style="{StaticResource NeuButton}"
                            Click="CancelButton_Click" Height="42"
                            IsCancel="True"/>
                    <Button Grid.Column="2" x:Name="SaveButton"
                            Style="{StaticResource NeuButtonAccent}"
                            Click="SaveButton_Click" Height="42"
                            IsDefault="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Enregistrer"
                                       FontFamily="{StaticResource NeuFontFamily}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Supprimer (mode édition uniquement) -->
                <Button x:Name="DeleteButton"
                        Style="{StaticResource NeuButtonDanger}"
                        Click="DeleteButton_Click" Height="38"
                        Margin="0,10,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑️" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Supprimer le produit"
                                   FontFamily="{StaticResource NeuFontFamily}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2"
                Background="{StaticResource NeuSurfaceBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource NeuDividerBrush}"
                Padding="28,10">
            <TextBlock x:Name="FooterTextBlock" Text="Prêt"
                       FontFamily="{StaticResource NeuMonoFont}" FontSize="11"
                       Foreground="{StaticResource NeuTextTertiaryBrush}"
                       HorizontalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
