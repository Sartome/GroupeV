<Window x:Class="GroupeV.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GroupeV — Connexion"
        MinHeight="560" MinWidth="420"
        Height="620" Width="480"
        Background="{StaticResource NeuBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Conteneur centré — carte blanche sur fond gris -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Carte principale -->
        <Border Grid.Row="0"
                Background="{StaticResource NeuSurfaceBrush}"
                BorderThickness="1"
                BorderBrush="{StaticResource NeuDividerBrush}"
                CornerRadius="0"
                Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Formulaire -->
                </Grid.RowDefinitions>

                <!-- ═══ HEADER ═══ -->
                <Border Grid.Row="0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource NeuDividerBrush}"
                        Padding="40,32,40,24">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Logo -->
                        <Border Width="52" Height="52" CornerRadius="12"
                                Background="{StaticResource NeuAccentBgBrush}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="€" FontSize="26" FontWeight="Bold"
                                       Foreground="{StaticResource NeuAccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock x:Name="TitleText" Text="Terminal Vendeur"
                                   FontFamily="{StaticResource NeuFontFamily}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource NeuTextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Connectez-vous à votre espace"
                                   FontFamily="{StaticResource NeuFontFamily}"
                                   FontSize="13"
                                   Foreground="{StaticResource NeuTextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ═══ FORMULAIRE ═══ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,28,40,32">

                        <!-- Message de statut (erreur / info) -->
                        <Border x:Name="StatusBorder"
                                Background="{StaticResource NeuDangerBadgeBgBrush}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource NeuDangerBadgeBgBrush}"
                                CornerRadius="6" Padding="14,10"
                                Margin="0,0,0,20"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="13"
                                           Foreground="{StaticResource NeuDangerBadgeFgBrush}"
                                           Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusTextBlock" Text=""
                                           FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                                           Foreground="{StaticResource NeuDangerBadgeFgBrush}"
                                           TextWrapping="Wrap" FontWeight="Medium"/>
                            </StackPanel>
                        </Border>

                        <!-- Champ Email -->
                        <StackPanel x:Name="EmailPanel" Margin="0,0,0,18"
                                    RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TranslateTransform/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="Adresse email"
                                       FontFamily="{StaticResource NeuFontFamily}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="EmailTextBox"
                                     Style="{StaticResource NeuTextBox}"
                                     MaxLength="255"
                                     AutomationProperties.Name="Adresse email"/>
                        </StackPanel>

                        <!-- Champ Mot de passe -->
                        <StackPanel x:Name="PasswordPanel" Margin="0,0,0,16"
                                    RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TranslateTransform/>
                            </StackPanel.RenderTransform>
                            <TextBlock Text="Mot de passe"
                                       FontFamily="{StaticResource NeuFontFamily}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <Grid>
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource NeuPasswordBox}"
                                             MaxLength="128"
                                             AutomationProperties.Name="Mot de passe"/>
                                <TextBox x:Name="PasswordRevealBox"
                                         Style="{StaticResource NeuTextBox}"
                                         MaxLength="128"
                                         Visibility="Collapsed"
                                         AutomationProperties.Name="Mot de passe (visible)"/>
                                <Button x:Name="TogglePasswordBtn"
                                        Content="👁"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,6,0" Padding="8,4" FontSize="14"
                                        Click="TogglePassword_Click" Cursor="Hand"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource NeuTextTertiaryBrush}"
                                        ToolTip="Afficher / Masquer le mot de passe"
                                        AutomationProperties.Name="Afficher le mot de passe"/>
                            </Grid>
                        </StackPanel>

                        <!-- Rester connecté -->
                        <StackPanel x:Name="RememberMePanel"
                                    Orientation="Horizontal" Margin="0,0,0,24"
                                    RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TranslateTransform/>
                            </StackPanel.RenderTransform>
                            <CheckBox x:Name="StayConnectedCheckBox"
                                      Style="{StaticResource NeuCheckBox}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Rester connecté"
                                       FontFamily="{StaticResource NeuFontFamily}"
                                       FontSize="13"
                                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Bouton Connexion -->
                        <Button x:Name="LoginButton"
                                Style="{StaticResource NeuButtonAccent}"
                                Click="LoginButton_Click"
                                Height="44" FontSize="14" FontWeight="SemiBold"
                                Margin="0,0,0,0"
                                RenderTransformOrigin="0.5,0.5"
                                AutomationProperties.Name="Se connecter">
                            <Button.RenderTransform>
                                <TranslateTransform/>
                            </Button.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔑" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Se connecter"
                                           FontFamily="{StaticResource NeuFontFamily}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="1"
                Background="{StaticResource NeuSurfaceBrush}"
                BorderThickness="1,0,1,1"
                BorderBrush="{StaticResource NeuDividerBrush}"
                Padding="24,12">
            <Grid>
                <TextBlock Text="Base de données : DDEV — sellandbuy"
                           FontFamily="{StaticResource NeuMonoFont}" FontSize="11"
                           Foreground="{StaticResource NeuTextTertiaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Fermer"
                        HorizontalAlignment="Right"
                        Style="{StaticResource NeuButtonDanger}"
                        Click="CloseButton_Click"
                        Padding="14,7" FontSize="12"/>
            </Grid>
        </Border>

    </Grid>
</Window>
