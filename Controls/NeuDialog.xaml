<Window x:Class="GroupeV.Controls.NeuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GroupeV"
        SizeToContent="WidthAndHeight"
        MinWidth="360" MaxWidth="500"
        Background="{StaticResource NeuBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True">

    <!-- Carte blanche centrée sur fond gris -->
    <Border Background="{StaticResource NeuSurfaceBrush}"
            BorderThickness="1"
            BorderBrush="{StaticResource NeuDividerBrush}">

        <StackPanel Margin="32,28,32,24">

            <!-- Icône -->
            <Border x:Name="IconBorder"
                    Width="48" Height="48" CornerRadius="12"
                    HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock x:Name="IconText" Text="ℹ"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Titre -->
            <TextBlock x:Name="TitleTextBlock" Text="Titre"
                       FontFamily="{StaticResource NeuFontFamily}"
                       FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource NeuTextPrimaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Margin="0,0,0,8"/>

            <!-- Message -->
            <TextBlock x:Name="MessageTextBlock" Text="Message"
                       FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                       Foreground="{StaticResource NeuTextSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,24" MaxWidth="400" LineHeight="20"/>

            <!-- Boutons -->
            <StackPanel x:Name="ButtonPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="PrimaryButton" Content="OK"
                        Style="{StaticResource NeuButtonAccent}"
                        Click="PrimaryButton_Click"
                        MinWidth="110" Height="40" Margin="4,0"/>
                <Button x:Name="SecondaryButton" Content="Annuler"
                        Style="{StaticResource NeuButton}"
                        Click="SecondaryButton_Click"
                        MinWidth="110" Height="40" Margin="4,0"
                        Visibility="Collapsed"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
