<Window x:Class="GroupeV.TicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support — Mes tickets"
        Width="920" Height="660"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource NeuBackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Contenu -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource NeuSurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource NeuDividerBrush}"
                Padding="24,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Support &amp; Tickets"
                               FontFamily="{StaticResource NeuFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource NeuTextPrimaryBrush}"
                               AutomationProperties.Name="Support et Tickets"/>
                    <TextBlock Text="Créez un ticket ou suivez vos demandes d'assistance"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="12"
                               Foreground="{StaticResource NeuTextSecondaryBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Content="✕  Fermer"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource NeuButton}"
                        Padding="14,8" FontSize="12"
                        Click="Close_Click"
                        AutomationProperties.Name="Fermer la fenêtre"/>
            </Grid>
        </Border>

        <!-- ═══ CONTENU PRINCIPAL ═══ -->
        <Grid Grid.Row="1" Margin="16,14,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- GAUCHE : Liste des tickets -->
            <Border Grid.Column="0" Style="{StaticResource NeuCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Bouton nouveau ticket -->
                    <Border Grid.Row="0" Padding="12,12,12,8"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource NeuDividerBrush}">
                        <Button Content="➕  Nouveau ticket"
                                Style="{StaticResource NeuButtonAccent}"
                                Height="36" FontSize="12"
                                Click="NewTicket_Click"/>
                    </Border>

                    <!-- Liste -->
                    <ListBox Grid.Row="1" x:Name="TicketListBox"
                             Background="Transparent"
                             BorderThickness="0" Padding="8"
                             SelectionChanged="TicketListBox_SelectionChanged"
                             AutomationProperties.Name="Liste des tickets">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"       Value="Transparent"/>
                                <Setter Property="BorderThickness"  Value="0"/>
                                <Setter Property="Padding"          Value="0"/>
                                <Setter Property="Margin"           Value="0,2"/>
                                <Setter Property="Cursor"           Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBd" CornerRadius="6" Padding="12,10"
                                                    Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background"
                                                            Value="{StaticResource NeuInputBgBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBd" Property="Background"
                                                            Value="{StaticResource NeuAccentBgBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Titre}"
                                               FontFamily="{StaticResource NeuFontFamily}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource NeuTextPrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding StatutEmoji}"
                                                   FontFamily="{StaticResource NeuFontFamily}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource NeuTextSecondaryBrush}"/>
                                        <TextBlock Text=" · " FontSize="11"
                                                   Foreground="{StaticResource NeuTextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding DateFormate}"
                                                   FontFamily="{StaticResource NeuMonoFont}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource NeuTextTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- DROITE : Conversation -->
            <Border Grid.Column="2" Style="{StaticResource NeuCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- En-tête ticket -->
                        <RowDefinition Height="*"/>
                        <!-- Messages -->
                        <RowDefinition Height="Auto"/>
                        <!-- Zone de réponse -->
                    </Grid.RowDefinitions>

                    <!-- En-tête ticket sélectionné -->
                    <Border Grid.Row="0" Padding="18,14"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource NeuDividerBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="TicketTitleText" Text="Sélectionnez un ticket"
                                           FontFamily="{StaticResource NeuFontFamily}"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource NeuTextPrimaryBrush}"/>
                                <TextBlock x:Name="TicketStatusText" Text=""
                                           FontFamily="{StaticResource NeuFontFamily}" FontSize="11"
                                           Foreground="{StaticResource NeuTextSecondaryBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button x:Name="CloseTicketBtn"
                                    Content="🔒  Fermer le ticket"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Style="{StaticResource NeuButtonDanger}"
                                    Padding="12,6" FontSize="11"
                                    Visibility="Collapsed"
                                    Click="CloseTicket_Click"/>
                        </Grid>
                    </Border>

                    <!-- Messages -->
                    <ScrollViewer Grid.Row="1" x:Name="MessagesScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16,12">
                        <StackPanel x:Name="MessagesPanel"/>
                    </ScrollViewer>

                    <!-- État vide -->
                    <TextBlock Grid.Row="1" x:Name="EmptyStateText"
                               Text="Aucun ticket sélectionné.&#x0a;Sélectionnez un ticket à gauche ou créez-en un nouveau."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontFamily="{StaticResource NeuFontFamily}" FontSize="13"
                               Foreground="{StaticResource NeuTextSecondaryBrush}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="40"/>

                    <!-- Zone de réponse -->
                    <Border Grid.Row="2" x:Name="ReplyArea"
                            Padding="14,12"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{StaticResource NeuDividerBrush}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="ReplyBox"
                                     Style="{StaticResource NeuTextBox}"
                                     Height="42" FontSize="13"
                                     KeyDown="ReplyBox_KeyDown"
                                     AutomationProperties.Name="Répondre au ticket"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource NeuButtonAccent}"
                                    Height="42" Padding="18,0" FontSize="13"
                                    Click="SendReply_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Envoyer" FontFamily="{StaticResource NeuFontFamily}"
                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text=" ▶" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
